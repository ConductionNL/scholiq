{
  "$schema": "https://raw.githubusercontent.com/ConductionNL/nextcloud-vue/main/src/schemas/app-manifest.schema.json",
  "version": "0.1.0",
  "dependencies": [
    "openregister",
    "openconnector"
  ],
  "menu": [
    {
      "id": "Dashboard",
      "label": "Dashboard",
      "icon": "icon-category-dashboard",
      "route": "Dashboard",
      "order": 10
    },
    {
      "id": "Courses",
      "label": "Courses",
      "icon": "icon-folder",
      "route": "Courses",
      "order": 20
    },
    {
      "id": "Enrolments",
      "label": "Enrolments",
      "icon": "icon-group",
      "route": "Enrolments",
      "order": 30
    },
    {
      "id": "Credentials",
      "label": "Credentials",
      "icon": "icon-checkmark",
      "route": "Credentials",
      "order": 40
    },
    {
      "id": "Compliance",
      "label": "Compliance",
      "icon": "icon-menu-sidebar",
      "route": "Compliance",
      "order": 50
    },
    {
      "id": "Documentation",
      "label": "Documentation",
      "icon": "icon-info",
      "href": "https://docs.scholiq.nl",
      "section": "settings",
      "order": 90
    },
    {
      "id": "Settings",
      "label": "Settings",
      "icon": "icon-settings",
      "route": "Settings",
      "section": "settings",
      "order": 99
    }
  ],
  "pages": [
    {
      "id": "Dashboard",
      "route": "/",
      "type": "dashboard",
      "title": "scholiq.page.dashboard.title",
      "config": {
        "widgets": [],
        "layout": []
      }
    },
    {
      "id": "Courses",
      "route": "/courses",
      "type": "index",
      "title": "Courses",
      "config": {
        "register": "scholiq",
        "schema": "Course"
      }
    },
    {
      "id": "Enrolments",
      "route": "/enrolments",
      "type": "index",
      "title": "Enrolments",
      "config": {
        "register": "scholiq",
        "schema": "Enrolment"
      }
    },
    {
      "id": "Credentials",
      "route": "/credentials",
      "type": "index",
      "title": "Credentials",
      "config": {
        "register": "scholiq",
        "schema": "Credential"
      }
    },
    {
      "id": "Compliance",
      "route": "/compliance",
      "type": "dashboard",
      "title": "Compliance",
      "config": {
        "widgets": [
          {
            "id": "coverage-grid",
            "title": "scholiq.widget.coverage_grid",
            "type": "custom"
          },
          {
            "id": "attestation-count",
            "title": "scholiq.widget.attestation_count",
            "type": "custom"
          }
        ],
        "layout": [],
        "actions": [
          {
            "id": "viewInMydash",
            "label": "scholiq.action.viewInMydash"
          }
        ]
      }
    },
    {
      "id": "CourseDetail",
      "route": "/courses/:id",
      "type": "detail",
      "title": "Course Detail",
      "config": {
        "register": "scholiq",
        "schema": "Course"
      }
    },
    {
      "id": "LessonIndex",
      "route": "/courses/:courseId/lessons",
      "type": "index",
      "title": "Lessons",
      "config": {
        "register": "scholiq",
        "schema": "Lesson"
      }
    },
    {
      "id": "LessonDetail",
      "route": "/courses/:courseId/lessons/:id",
      "type": "detail",
      "title": "Lesson Detail",
      "config": {
        "register": "scholiq",
        "schema": "Lesson"
      }
    },
    {
      "id": "LessonPlayer",
      "route": "/courses/:courseId/lessons/:lessonId/play",
      "type": "custom",
      "title": "Lesson Player",
      "component": "LessonPlayer"
    },
    {
      "id": "Settings",
      "route": "/settings",
      "type": "custom",
      "title": "Settings",
      "component": "ScholiqSettings"
    },
    {
      "id": "EnrolmentDetail",
      "route": "/enrolments/:id",
      "type": "detail",
      "title": "Enrolment",
      "config": {
        "register": "scholiq",
        "schema": "Enrolment"
      }
    },
    {
      "id": "BulkEnrol",
      "route": "/enrolments/bulk",
      "type": "custom",
      "title": "Bulk Enrol",
      "config": {
        "component": "BulkEnrolModal"
      }
    },
    {
      "id": "Regulations",
      "route": "/compliance/regulations",
      "type": "index",
      "title": "scholiq.page.regulations.title",
      "config": {
        "register": "scholiq",
        "schema": "Regulation"
      }
    },
    {
      "id": "RegulationDetail",
      "route": "/compliance/regulations/:slug",
      "type": "detail",
      "title": "scholiq.page.regulation.detail.title",
      "config": {
        "register": "scholiq",
        "schema": "Regulation",
        "tabs": [
          "details",
          "auditTrail"
        ]
      }
    },
    {
      "id": "Attestations",
      "route": "/compliance/attestations",
      "type": "index",
      "title": "scholiq.page.attestations.title",
      "config": {
        "register": "scholiq",
        "schema": "Attestation",
        "readOnly": true
      }
    },
    {
      "id": "AttestationDetail",
      "route": "/compliance/attestations/:id",
      "type": "detail",
      "title": "scholiq.page.attestation.detail.title",
      "config": {
        "register": "scholiq",
        "schema": "Attestation",
        "readOnly": true,
        "tabs": [
          "details",
          "auditTrail"
        ]
      }
    },
    {
      "id": "AuditPackExport",
      "route": "/compliance/export",
      "type": "custom",
      "title": "scholiq.page.audit_pack_export.title",
      "config": {
        "component": "AuditPackExportModal"
      }
    },
    {
      "id": "CredentialDetail",
      "route": "/credentials/:id",
      "type": "detail",
      "title": "Credential",
      "config": {
        "register": "scholiq",
        "schema": "Credential"
      }
    },
    {
      "id": "CredentialVerify",
      "route": "/credentials/:id/verify",
      "type": "custom",
      "title": "Verify Credential",
      "component": "CredentialVerify"
    },
    {
      "id": "LearnerHome",
      "route": "/learner",
      "type": "dashboard",
      "title": "scholiq.page.learner.title",
      "config": {
        "widgets": [
          {
            "id": "my-mandatory-training",
            "title": "scholiq.widget.my_mandatory_training",
            "type": "custom"
          }
        ],
        "layout": []
      }
    },
    {
      "id": "AdminHealth",
      "route": "/admin/health",
      "type": "dashboard",
      "title": "scholiq.page.admin.health.title",
      "config": {
        "widgets": [
          {
            "id": "health-stats",
            "title": "scholiq.widget.health_stats",
            "type": "custom"
          }
        ],
        "layout": []
      }
    }
  ]
}
