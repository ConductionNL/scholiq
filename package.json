{
  "name": "scholiq",
  "version": "0.1.0",
  "license": "EUPL-1.2",
  "engines": {
    "node": "^20.0.0",
    "npm": "^10.0.0"
  },
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.config.js --progress",
    "dev": "NODE_ENV=development webpack --config webpack.config.js --progress",
    "watch": "NODE_ENV=development webpack --config webpack.config.js --progress --watch",
    "lint": "eslint src",
    "lint-fix": "npm run lint -- --fix",
    "stylelint": "stylelint src/**/*.vue src/**/*.scss src/**/*.css",
    "stylelint-fix": "stylelint src/**/*.vue src/**/*.scss src/**/*.css --fix",
    "check:manifest": "node tests/validate-manifest.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:register": "node tests/validate-register.js",
    "check:json-strict": "node tests/validate-json-strict.js",
    "check:specs": "npm run check:json-strict && npm run check:manifest && npm run check:register",
    "seed:e2e": "node tests/e2e/seed-example-data.mjs"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@conduction/nextcloud-vue": "^1.0.0-beta.97",
    "@nextcloud/auth": "^2.5.0",
    "@nextcloud/axios": "~2.5.2",
    "@nextcloud/dialogs": "^3.2.0",
    "@nextcloud/initial-state": "^2.2.0",
    "@nextcloud/l10n": "^2.0.1",
    "@nextcloud/router": "^2.0.1",
    "@nextcloud/vue": "^8.16.0",
    "babel-loader": "^10.1.1",
    "eslint-plugin-import": "^2.32.0",
    "node-polyfill-webpack-plugin": "^3.0.0",
    "pinia": "^2.1.7",
    "vue": "^2.7.14",
    "vue-material-design-icons": "^5.3.0",
    "vue-router": "^3.6.5"
  },
  "overrides": {
    "libxmljs2": "^0.37.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/config-helpers": "^0.4.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@nextcloud/browserslist-config": "^3.0.1",
    "@nextcloud/eslint-config": "^8.4.1",
    "@nextcloud/stylelint-config": "^2.4.0",
    "@nextcloud/webpack-vue-config": "^6.0.1",
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "css-loader": "~7.1.1",
    "eslint": "^8.56.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-vue": "^9.21.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "style-loader": "~4.0.0",
    "stylelint": "^15.11.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-loader": "^15.11.1",
    "vue-template-compiler": "^2.7.16",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.1"
  }
}
