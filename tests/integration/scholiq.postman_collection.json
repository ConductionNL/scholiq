{
	"info": {
		"_postman_id": "scholiq-collection",
		"name": "Scholiq Integration Tests",
		"description": "Active Newman collection — runs in CI on every push to `development`. Currently only the Nextcloud health check. As Hydra builds capability endpoints, the matching TDD-stub folder is moved here from `tests/wedge-scaffolds/scholiq-wedge.postman_collection.json` and its requests are enabled.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "basic",
		"basic": [
			{ "key": "username", "value": "{{adminUser}}", "type": "string" },
			{ "key": "password", "value": "{{adminPass}}", "type": "string" }
		]
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
		{ "key": "adminUser", "value": "admin", "type": "string" },
		{ "key": "adminPass", "value": "admin", "type": "string" }
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Nextcloud status",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": "{{baseUrl}}/status.php",
						"description": "Verify Nextcloud is running."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Nextcloud is running', function () {",
									"    pm.response.to.have.status(200);",
									"    const json = pm.response.json();",
									"    pm.expect(json.installed).to.be.true;",
									"});"
								]
							}
						}
					]
				}
			]
		}
	]
}
