								]
							}
						}
					]
				},
				{
					"name": "Create Enrolment 3 (active — will complete)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "OCS-APIRequest", "value": "true" }
						],
						"url": "{{baseUrl}}/apps/openregister/api/objects/scholiq/newman-cov-enrolment-tmp",
						"body": {
							"mode": "raw",
							"raw": "{\"learnerId\":\"cov-learner-3\",\"regulationSlug\":\"newman-cov-slug\",\"lifecycle\":\"active\"}"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('E3 created', function () { pm.response.to.have.status(201); });",
									"pm.collectionVariables.set('cov_e3Id', pm.response.json().id);"
								]
