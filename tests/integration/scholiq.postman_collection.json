									"    pm.expect(completed).to.equal(2, '2 should be completed');",
									"    const pct = (completed / total) * 100;",
									"    pm.expect(pct).to.be.within(60, 70, 'Coverage should be ~66.6%');",
									"    console.log('Coverage: ' + pct.toFixed(1) + '% (' + completed + '/' + total + ')');",
