		{
			"name": "attestation signing",
			"description": "Creates a temp Attestation schema with a 'sign' transition, creates an Attestation in 'draft' state, PATCHes lifecycle to 'signed', asserts the response has a signature field (written by AttestationSigningGuard).\n\nNOTE: AttestationSigningGuard is registered as an OR lifecycle pre-hook and runs server-side on the PATCH. If the guard is not active (e.g. app not fully initialised) the signature field may be null.",
			"item": [
				{
					"name": "Setup — create temp Attestation schema",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "OCS-APIRequest", "value": "true" }
						],
						"url": "{{baseUrl}}/apps/openregister/api/schemas",
						"body": {
							"mode": "raw",
							"raw": "{\"title\":\"newman-attestation-tmp\",\"slug\":\"newman-attestation-tmp\",\"register\":\"scholiq\",\"properties\":{\"regulationSlug\":{\"type\":\"string\"},\"attestedBy\":{\"type\":\"string\"},\"signature\":{\"type\":\"string\"},\"lifecycle\":{\"type\":\"string\",\"default\":\"draft\"}}}"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Temp attestation schema created', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"pm.collectionVariables.set('att_schemaId', pm.response.json().id);"
								]
							}
						}
					]
				},
				{
					"name": "Create Attestation (draft)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "OCS-APIRequest", "value": "true" }
						],
						"url": "{{baseUrl}}/apps/openregister/api/objects/scholiq/newman-attestation-tmp",
						"body": {
							"mode": "raw",
							"raw": "{\"regulationSlug\":\"newman-sign-test\",\"attestedBy\":\"admin\",\"lifecycle\":\"draft\"}"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Attestation created (201)', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.collectionVariables.set('att_attestationId', pm.response.json().id);"
								]
							}
						}
					]
				},
				{
					"name": "Sign Attestation (PATCH lifecycle → signed)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "OCS-APIRequest", "value": "true" }
						],
						"url": "{{baseUrl}}/apps/openregister/api/objects/scholiq/newman-attestation-tmp/{{att_attestationId}}",
						"body": {
							"mode": "raw",
							"raw": "{\"lifecycle\":\"signed\",\"signature\":\"pending\"}"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Sign PATCH accepted (200)', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response payload has signature field', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('signature');",
									"    // AttestationSigningGuard replaces 'pending' with real RS256 JWS if the app",
									"    // signing key is set up. Accept any non-null string.",
									"    pm.expect(json.signature).to.be.a('string').and.not.empty;",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Cleanup — delete Attestation",
