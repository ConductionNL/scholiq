									"});",
									"pm.test('Coverage ≈ 66.6% (2 of 3 completed)', function () {",
									"    const json = pm.response.json();",
									"    const results = json.results || [];",
									"    const total = results.length;",
									"    const completed = results.filter(r => r.lifecycle === 'completed').length;",
